# Ադմինի մուտք /admin էջ:
# Պատճենեք այս ֆայլը .env.local-ում և մուտքագրեք իրական արժեքները:

# Ադմինի լոգին (ցանկացած տող)
ADMIN_LOGIN=admin

# Ադմինի գաղտնաբառ — պետք է լինի երկար և պատահական:
# Կարող եք ստեղծել՝ node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace_me_with_a_long_random_token

# Vercel Blob — ֆայլերի և տվյալների պահպանության համար (production):
# Ստեղծեք Blob Store-ը Vercel Dashboard → Storage → Create → Blob-ում:
# Կամ՝ vercel env pull .env.local հրամանով ավտոմատ ստացեք:
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxx
BLOB_STORE_ID=store_xxxxxxxxxx
